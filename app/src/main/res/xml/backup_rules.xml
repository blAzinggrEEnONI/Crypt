<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <exclude domain="database" path="crypt_database.db"/>
    <exclude domain="database" path="crypt_database.db-wal"/>
    <exclude domain="database" path="crypt_database.db-shm"/>
    <exclude domain="sharedpref" path="auth_prefs.xml"/>
    <exclude domain="sharedpref" path="display_prefs.xml"/>
</full-backup-content>